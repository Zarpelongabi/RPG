<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/battle_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clickable="true"
    android:focusable="true">

    <!-- Fundo de Batalha -->
    <ImageView
        android:id="@+id/iv_battle_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/battlebg2" />

    <!-- Área Superior: Inimigo -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="50dp"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iv_enemy_battle"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/sprite_goblin" />

        <TextView
            android:id="@+id/tv_enemy_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Goblin"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Área Inferior: Jogador -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="100dp"
        android:layout_marginStart="50dp"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iv_player_battle"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/personagem_battle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Herói"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Menu de Comandos (Estilo Pokémon) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="bottom"
        android:background="#DD000000"
        android:orientation="horizontal"
        android:padding="10dp">

        <TextView
            android:id="@+id/tv_battle_message"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:text="O que o Herói fará?"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:columnCount="2"
            android:rowCount="2">

            <Button
                android:id="@+id/btn_attack"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="ATACAR" />

            <Button
                android:id="@+id/btn_skill"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="SKILL" />

            <Button
                android:id="@+id/btn_item"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="ITEM" />

            <Button
                android:id="@+id/btn_run"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="FUGIR" />
        </GridLayout>
    </LinearLayout>
</FrameLayout>
