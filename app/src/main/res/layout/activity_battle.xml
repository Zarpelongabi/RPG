<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Fundo de Batalha -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/battlebg2" />

    <!-- STATUS DO INIMIGO -->
    <RelativeLayout
        android:id="@+id/enemy_status_container"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="40dp"
        android:layout_marginStart="20dp"
        android:background="@drawable/box_message"
        android:padding="8dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tv_enemy_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GOBLIN"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"/>

        <ProgressBar
            android:id="@+id/pb_enemy_hp"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_below="@id/tv_enemy_name"
            android:layout_marginTop="6dp"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:progressTint="#4CAF50" />
    </RelativeLayout>

    <ImageView
        android:id="@+id/iv_enemy_battle"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="180dp"
        android:layout_marginBottom="190dp"
        android:scaleType="fitCenter" />

    <!-- STATUS DO JOGADOR (HUD DINÂMICA) - Reduzida e posicionada -->
    <RelativeLayout
        android:layout_width="150dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="140dp"
        android:layout_marginEnd="5dp">

        <ImageView
            android:id="@+id/iv_hp_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/hud_100hp" />

        <ProgressBar
            android:id="@+id/pb_player_hp"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="80dp"
            android:layout_height="4dp"
            android:layout_marginStart="51dp"
            android:layout_marginTop="22dp"
            android:progressDrawable="@drawable/hp_mask"
            android:rotation="180"
            android:visibility="visible" />

        <ProgressBar
            android:id="@+id/pb_player_xp"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="80dp"
            android:layout_height="4dp"
            android:layout_marginStart="51dp"
            android:layout_marginTop="35dp"
            android:progressDrawable="@drawable/hp_mask"
            android:rotation="180"
            android:visibility="visible" />
    </RelativeLayout>

    <ImageView
        android:id="@+id/iv_player_battle"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="180dp"
        android:layout_marginBottom="110dp"
        android:scaleType="fitCenter" />

    <!-- CAIXA DE MENSAGENS E COMANDOS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="bottom"
        android:background="@drawable/box_message"
        android:orientation="horizontal"
        android:padding="12dp"
        android:layout_margin="5dp">

        <TextView
            android:id="@+id/tv_battle_message"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.3"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:text="O que o Herói fará?"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:fontFamily="serif"
            android:clickable="true"
            android:focusable="true" />

        <GridLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:columnCount="2"
            android:rowCount="2">

            <Button android:id="@+id/btn_attack" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="44dp" android:text="LUTAR" android:backgroundTint="#B22222" android:layout_margin="2dp" android:textSize="12sp" android:textStyle="bold" />
            <Button android:id="@+id/btn_skill" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="44dp" android:text="SKILL" android:backgroundTint="#4682B4" android:layout_margin="2dp" android:textSize="12sp" />
            <Button android:id="@+id/btn_item" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="44dp" android:text="BOLSA" android:backgroundTint="#556B2F" android:layout_margin="2dp" android:textSize="12sp" />
            <Button android:id="@+id/btn_run" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="44dp" android:text="FUGIR" android:backgroundTint="#555555" android:layout_margin="2dp" android:textSize="12sp" />
        </GridLayout>
    </LinearLayout>

    <include layout="@layout/layout_game_over" />

</FrameLayout>
