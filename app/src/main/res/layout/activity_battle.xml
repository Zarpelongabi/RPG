<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Fundo de Batalha -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/battlebg2" />

    <!-- STATUS DO INIMIGO (Estilo GBA Tradicional) -->
    <RelativeLayout
        android:layout_width="190dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="35dp"
        android:layout_marginStart="20dp"
        android:background="#E8E8E8"
        android:padding="6dp"
        android:elevation="4dp">

        <!-- Borda superior preta estilo Pokemon -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#333333"
            android:layout_alignParentTop="true"/>

        <TextView
            android:id="@+id/tv_enemy_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="GOBLIN"
            android:textColor="#444444"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_enemy_level_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="4dp"
            android:text="Lv: 5"
            android:textColor="#444444"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Barra de HP do Inimigo -->
        <ProgressBar
            android:id="@+id/pb_enemy_hp"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_below="@id/tv_enemy_name"
            android:layout_marginTop="6dp"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:progressTint="#4CAF50"
            android:backgroundTint="#888888" />

        <!-- Borda inferior estilo Pokemon -->
        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#333333"
            android:layout_below="@id/pb_enemy_hp"
            android:layout_marginTop="4dp"/>
    </RelativeLayout>

    <!-- SPRITE DO INIMIGO -->

    <!-- STATUS DO JOGADOR (Seu Quadro de Madeira) -->

    <ImageView
        android:id="@+id/iv_enemy_battle"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="50dp" />

    <RelativeLayout
        android:layout_width="320dp"
        android:layout_height="120dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="125dp"
        android:layout_marginEnd="5dp">

        <ImageView
            android:id="@+id/iv_hp_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/barra_hud" />

        <!-- RETRATO DO PERSONAGEM (REMOVIDO) -->

        <!-- Nome do Herói (REMOVIDO PARA LIMPAR O HUD) -->
        <TextView
            android:id="@+id/tv_player_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="85dp"
            android:layout_marginTop="16dp"
            android:text=""
            android:visibility="gone" />

        <!-- NÍVEL: Reposicionado para ficar exatamente à frente de "LVL:" na imagem barra_hud -->
        <TextView
            android:id="@+id/tv_player_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="145dp"
            android:layout_marginTop="31dp"
            android:text="1"
            android:textColor="#FFEB3B"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- BARRA DE HP (MÁSCARA) -->
        <ProgressBar
            android:id="@+id/pb_player_hp"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="168dp"
            android:layout_height="8dp"
            android:layout_marginStart="107dp"
            android:layout_marginTop="46dp"
            android:progress="100"
            android:progressDrawable="@drawable/hp_mask" />

        <!-- VALORES DE HP (REMOVIDOS CONFORME PEDIDO) -->
        <TextView
            android:id="@+id/tv_player_hp_values"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <!-- BARRA DE EXP (MÁSCARA) -->
        <ProgressBar
            android:id="@+id/pb_player_xp"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="168dp"
            android:layout_height="8dp"
            android:layout_marginStart="107dp"
            android:layout_marginTop="73dp"
            android:progress="0"
            android:progressDrawable="@drawable/hp_mask" />

        <!-- VALORES DE XP (REMOVIDOS CONFORME PEDIDO) -->
        <TextView
            android:id="@+id/tv_player_xp_values"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- SPRITE DO JOGADOR -->

    <!-- CAIXA DE MENSAGEM (Estilo Pokemon) -->

    <ImageView
        android:id="@+id/iv_player_battle"
        android:layout_width="230dp"
        android:layout_height="230dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="15dp"
        android:layout_marginBottom="85dp"
        android:src="@drawable/personagem_battle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="115dp"
        android:layout_gravity="bottom"
        android:background="#E0222222"
        android:orientation="horizontal"
        android:padding="10dp"
        android:elevation="10dp">

        <TextView
            android:id="@+id/tv_battle_message"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:text="O que o Herói fará?"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:lineSpacingExtra="4dp" />

        <!-- Menu de Comandos (Grade 2x2 clássica) -->
        <GridLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:columnCount="2"
            android:rowCount="2">

            <Button
                android:id="@+id/btn_attack"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="42dp"
                android:text="LUTAR"
                android:textSize="12sp"
                android:backgroundTint="#A04038"
                android:layout_margin="2dp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_skill"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="42dp"
                android:text="SKILL"
                android:textSize="12sp"
                android:layout_margin="2dp"
                android:backgroundTint="#506090"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_item"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="42dp"
                android:text="BOLSA"
                android:textSize="12sp"
                android:layout_margin="2dp"
                android:backgroundTint="#508050"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_run"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="42dp"
                android:text="FUGIR"
                android:textSize="12sp"
                android:layout_margin="2dp"
                android:backgroundTint="#606060"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </GridLayout>
    </LinearLayout>
</FrameLayout>
