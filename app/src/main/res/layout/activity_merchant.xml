<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/merchant_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/iv_merchant_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"

        android:id="@+id/layout_shop_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"


        <View
            android:id="@+id/btn_prev_category"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/btn_next_category"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

        <View
            android:id="@+id/btn_close_merchant"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

    <LinearLayout
        android:id="@+id/layout_merchant_dialog"
        android:layout_gravity="bottom|center_horizontal"
        android:background="@drawable/box_message"
        android:orientation="vertical"
        android:padding="15dp"
        android:clickable="true"

        <TextView
            android:id="@+id/tv_merchant_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textColor="#FFD700"
    </LinearLayout>

    <!-- Overlay Detalhes Item -->
    <FrameLayout
        android:id="@+id/item_detail_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/box_message"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_detail_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFD700"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iv_detail_icon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_margin="10dp"

            <TextView
                android:id="@+id/tv_detail_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tv_detail_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#00FF00" />

            <Button
                android:id="@+id/btn_buy_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:backgroundTint="#2E8B57" />

            <Button
                android:id="@+id/btn_close_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="CANCELAR"
                android:backgroundTint="#A52A2A" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
