<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/merchant_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/iv_merchant_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/floresta" />

    <!-- Área da Loja (Usando ConstraintLayout para alinhamento por PORCENTAGEM) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_shop_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_shop_shelf_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@drawable/loja_armas" />

        <!-- Overlay de Itens: Alinhado com as prateleiras -->
        <GridLayout
            android:id="@+id/grid_shop_items"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.75"
            app:layout_constraintHeight_percent="0.45"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintVertical_bias="0.42"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:columnCount="5"
            android:rowCount="3"
            android:useDefaultMargins="false" />

        <!-- Navegação: Setas da roda -->
        <View
            android:id="@+id/btn_prev_category"
            android:layout_width="70dp"
            android:layout_height="70dp"
            app:layout_constraintHorizontal_bias="0.41"
            app:layout_constraintVertical_bias="0.86"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/btn_next_category"
            android:layout_width="70dp"
            android:layout_height="70dp"
            app:layout_constraintHorizontal_bias="0.59"
            app:layout_constraintVertical_bias="0.86"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <!-- Moedas: Slot marrom esquerdo superior -->
        <TextView
            android:id="@+id/tv_shop_coins_internal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintHorizontal_bias="0.315"
            app:layout_constraintVertical_bias="0.778"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="1" />

        <!-- Botão Exit: Sobre o gráfico 'Exit' -->
        <View
            android:id="@+id/btn_close_merchant"
            android:layout_width="140dp"
            android:layout_height="45dp"
            app:layout_constraintHorizontal_bias="0.27"
            app:layout_constraintVertical_bias="0.895"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <!-- Total: Slot marrom direito superior -->
        <TextView
            android:id="@+id/tv_cart_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintHorizontal_bias="0.765"
            app:layout_constraintVertical_bias="0.778"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="1" />

        <!-- Carrinho: Nicho inferior direito -->
        <ImageButton
            android:id="@+id/btn_go_to_checkout"
            android:layout_width="140dp"
            android:layout_height="45dp"
            app:layout_constraintHorizontal_bias="0.73"
            app:layout_constraintVertical_bias="0.895"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/carrinho" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Personagem Comerciante (Garante que os pés fiquem no chão com fitEnd) -->
    <ImageView
        android:id="@+id/iv_merchant_sprite"
        android:layout_width="350dp"
        android:layout_height="400dp"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="0dp"
        android:scaleType="fitEnd"
        android:elevation="10dp" />

    <!-- Balão de Fala do Comerciante -->
    <LinearLayout
        android:id="@+id/layout_merchant_dialog"
        android:layout_width="450dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="0dp"
        android:background="@drawable/box_message"
        android:orientation="vertical"
        android:padding="15dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="20dp">

        <TextView
            android:id="@+id/tv_merchant_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="..."
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="5dp"
            android:text="[Toque para continuar]"
            android:textColor="#FFD700"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Overlay Detalhes Item -->
    <FrameLayout
        android:id="@+id/item_detail_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/box_message"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_detail_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ITEM"
                android:textColor="#FFD700"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iv_detail_icon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_margin="10dp"
                android:src="@drawable/moedas" />

            <TextView
                android:id="@+id/tv_detail_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Info"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tv_detail_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Preço"
                android:textColor="#00FF00" />

            <Button
                android:id="@+id/btn_buy_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="COLOCAR NO CARRINHO"
                android:backgroundTint="#2E8B57" />

            <Button
                android:id="@+id/btn_close_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="CANCELAR"
                android:backgroundTint="#A52A2A" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
