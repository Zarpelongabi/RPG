<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/container_name_input"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="520dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/box_message"
        android:orientation="vertical"
        android:padding="15dp">

        <!-- Top Display Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="15dp"
            android:padding="10dp"
            android:background="#33000000">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/sprite_batalhapersonagem"
                android:scaleType="centerInside"
                android:layout_marginEnd="15dp"/>

            <TextView
                android:id="@+id/tv_display_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="_________"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="1"/>
        </LinearLayout>

        <!-- Keyboard Area: Letters + Actions on the right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Letters Grid -->
            <GridLayout
                android:id="@+id/grid_letters"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:columnCount="7"
                android:alignmentMode="alignBounds"
                android:useDefaultMargins="false">
                <!-- Letters inserted via code -->
            </GridLayout>

            <!-- Sidebar Actions (Pokemon Style) -->
            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="10dp">

                <Button
                    android:id="@+id/btn_name_case"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="abc / ABC"
                    android:textSize="12sp"
                    android:backgroundTint="#4682B4"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btn_name_backspace"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="APAGAR"
                    android:textSize="12sp"
                    android:backgroundTint="#B22222"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btn_name_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:text="OK"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:backgroundTint="#2E8B57"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
